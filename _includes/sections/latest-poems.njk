<section class="editorial-section">
  <h2 class="section-title">Latest Poems</h2>

  {% set posts = collections.poems | reverse %}

  {% if posts.length > 0 %}
  <div class="editorial-grid">

    <!-- Featured -->
    {% set featured = posts[0] %}
    <div class="featured" style="background-image: url('{{ featured.data.image }}')">
      <div class="overlay">
        <h3>
          <a href="{{ featured.url }}">{{ featured.data.title }}</a>
        </h3>
        <p class="meta">
          {{ featured.date | date("MMMM dd, yyyy") }}
        </p>
        <a class="btn" href="{{ featured.url }}">Read →</a>
      </div>
    </div>

    <!-- Side Posts -->
    <div class="side-posts">
      {% for post in posts.slice(1, 5) %}
      <div class="card">
        <div class="card-image"
             style="background-image: url('{{ post.data.image }}')"></div>
        <div class="card-content">
          <h4>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h4>
          <p class="meta">
            {{ post.date | date("MMMM dd, yyyy") }}
          </p>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
  {% endif %}
</section>
