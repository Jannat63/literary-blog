<section class="editorial-section">
  <h2 class="section-title">Latest Poems</h2>

  {% set posts = collections.poems %}


  {% if posts.length > 0 %}
  <div class="editorial-grid">

    {% set featured = posts[0] %}
    <div class="featured"
      {% if featured.data.image %}
      style="background-image: url('{{ featured.data.image }}')"
      {% endif %}>
      <div class="overlay">
        <h2>
          <a href="{{ featured.url }}">{{ featured.data.title }}</a>
        </h2>
        <p class="meta">
          {{ featured.date | date("MMMM dd, yyyy") }}
        </p>
        <a class="btn" href="{{ featured.url }}">Read →</a>
      </div>
    </div>

    <div class="side-posts">
      {% for post in posts.slice(1, 5) %}
      <div class="card">
        <div class="card-image"
          {% if post.data.image %}
          style="background-image: url('{{ post.data.image }}')"
          {% endif %}></div>

        <div class="card-content">
          <h3>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h3>
          <p class="meta">
            {{ post.date | date("MMMM dd, yyyy") }}
          </p>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
  {% endif %}
</section>
