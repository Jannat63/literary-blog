{% set latestStories = collections.stories | reverse | first(3) %}
<div class="home-section-block reveal">
  <span class="block-icon">📜</span>
  <h3 class="block-title">Latest Stories</h3>
  {% if latestStories.length %}
    <ul class="block-list">
      {% for story in latestStories %}
        <li><a href="{{ story.url }}">{{ story.data.title }}</a></li>
      {% endfor %}
    </ul>
    <a href="/stories/" class="block-more">Browse all stories →</a>
  {% else %}
    <p style="font-style:italic;color:var(--ink-faded);font-size:0.95rem;">No stories yet — check back soon.</p>
  {% endif %}
</div>
