<section class="editorial-section">
  <h2 class="section-title">Latest Stories</h2>

  {% assign posts = collections.stories | reverse %}

  <div class="editorial-grid">

    {% for post in posts limit:1 %}
    <div class="featured" style="background-image: url('{{ post.data.image }}')">
      <div class="overlay">
        <h3>
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h3>
        <p class="meta">{{ post.date | date: "%B %d, %Y" }}</p>
        <a class="btn" href="{{ post.url }}">Read →</a>
      </div>
    </div>
    {% endfor %}

    <div class="side-posts">
      {% for post in posts offset:1 limit:4 %}
      <div class="card">
        <div class="card-image"
             style="background-image: url('{{ post.data.image }}')"></div>
        <div class="card-content">
          <h4>
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h4>
          <p class="meta">{{ post.date | date: "%B %d, %Y" }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

  </div>
</section>
