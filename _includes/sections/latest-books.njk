{% set latestBooks = collections.books | reverse | first(3) %}
<div class="home-section-block reveal">
  <span class="block-icon">📚</span>
  <h3 class="block-title">Latest Books</h3>
  {% if latestBooks.length %}
    <ul class="block-list">
      {% for book in latestBooks %}
        <li><a href="{{ book.url }}">{{ book.data.title }}</a></li>
      {% endfor %}
    </ul>
    <a href="/books/" class="block-more">Browse all books →</a>
  {% else %}
    <p style="font-style:italic;color:var(--ink-faded);font-size:0.95rem;">No books yet — stay tuned.</p>
  {% endif %}
</div>
