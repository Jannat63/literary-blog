---
layout: layout.njk
title: Books
permalink: /books/
---

<h2 class="section-heading reveal">Books</h2>
<div class="section-rule reveal"><span>📚</span></div>

<div id="books-container">
  <div class="loading-state"><div class="spinner-small"></div>Loading from the archive…</div>
</div>

<script>
(function(){
  var apiUrl = getApiUrl();
  var container = document.getElementById('books-container');

  if (!apiUrl) {
    container.innerHTML = '<p class="empty-state">No database connected.</p>';
    return;
  }

  var cached = getCached('list_Books');
  if (cached) { render(cached); return; }

  fetch(apiUrl+'?action=list&sheet=Books')
    .then(function(r){ return r.json(); })
    .then(function(j){
      var data = j.data || [];
      setCached('list_Books', data);
      render(data);
    })
    .catch(function(){ container.innerHTML='<p class="empty-state">Could not load books.</p>'; });

  function render(rows) {
    var published = rows.filter(function(p){ return p.status!=='draft'; }).reverse();
    if (!published.length) {
      container.innerHTML='<p class="empty-state">No books shelved yet. The library awaits its volumes.</p>';
      return;
    }
    container.innerHTML = '<div class="books-grid">'+
      published.map(function(p){
        return '<a href="#" class="book-card reveal" data-post-id="'+esc(p.id)+'" data-post-sheet="Books">'+
          '<div class="book-spine"><span class="book-spine-title">'+esc(p.title)+'</span></div>'+
          '<div class="book-meta-title">'+esc(p.title)+'</div>'+
          (p.author ? '<div class="book-meta-author">'+esc(p.author)+'</div>' : '')+
        '</a>';
      }).join('')+
    '</div>';
    attachPostLinks(container);
  }
})();
</script>
