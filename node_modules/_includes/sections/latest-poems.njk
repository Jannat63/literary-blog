{% set latestPoems = collections.poems | reverse | first(3) %}
<div class="home-section-block reveal">
  <span class="block-icon">🪶</span>
  <h3 class="block-title">Latest Poems</h3>
  {% if latestPoems.length %}
    <ul class="block-list">
      {% for poem in latestPoems %}
        <li><a href="{{ poem.url }}">{{ poem.data.title }}</a></li>
      {% endfor %}
    </ul>
    <a href="/poems/" class="block-more">Browse all poems →</a>
  {% else %}
    <p style="font-style:italic;color:var(--ink-faded);font-size:0.95rem;">No poems yet — come back soon.</p>
  {% endif %}
</div>
