---
layout: layout.njk
title: Search
permalink: /search/
---

<h2 class="section-heading">Search the Archive</h2>
<div class="section-rule"><span>🔍</span></div>

<div class="search-wrap">
  <div class="search-form">
    <input type="text" id="search-input" class="search-input" placeholder="Search poems, stories, books…" autocomplete="off"/>
    <button class="search-btn" onclick="doSearch()">Search</button>
  </div>
  <div id="search-status" class="search-status"></div>
  <div id="search-results"></div>
</div>

<script>
(function(){
  var apiUrl = getApiUrl();
  var allData = null; /* loaded once, searched locally */

  /* Trigger on Enter */
  document.getElementById('search-input').addEventListener('keydown', function(e){
    if (e.key === 'Enter') doSearch();
  });

  /* Auto-focus */
  document.getElementById('search-input').focus();

  window.doSearch = function() {
    var query = document.getElementById('search-input').value.trim();
    var status  = document.getElementById('search-status');
    var results = document.getElementById('search-results');

    if (!query) { status.textContent = ''; results.innerHTML = ''; return; }
    if (!apiUrl) { status.textContent = 'No database connected.'; return; }

    if (allData) {
      runSearch(query);
      return;
    }

    status.textContent = 'Searching the archive…';
    var sheets = ['Poems','Stories','Books'];
    var promises = sheets.map(function(sheet){
      var cached = getCached('list_'+sheet);
      if (cached) return Promise.resolve({ sheet: sheet, data: cached });
      return fetch(apiUrl+'?action=list&sheet='+sheet)
        .then(function(r){ return r.json(); })
        .then(function(j){ setCached('list_'+sheet, j.data||[]); return { sheet: sheet, data: j.data||[] }; });
    });

    Promise.all(promises).then(function(res){
      allData = {};
      res.forEach(function(r){ allData[r.sheet] = r.data; });
      runSearch(query);
    }).catch(function(){
      status.textContent = 'Could not load data. Check your connection.';
    });
  };

  function runSearch(query) {
    var q = query.toLowerCase();
    var status  = document.getElementById('search-status');
    var results = document.getElementById('search-results');
    var total   = 0;
    var html    = '';

    ['Poems','Stories','Books'].forEach(function(sheet){
      var rows = (allData[sheet]||[]).filter(function(p){ return p.status !== 'draft'; });
      var matches = rows.filter(function(p){
        return (p.title   || '').toLowerCase().includes(q) ||
               (p.content || '').toLowerCase().includes(q) ||
               (p.excerpt || '').toLowerCase().includes(q) ||
               (p.author  || '').toLowerCase().includes(q);
      });
      if (!matches.length) return;
      total += matches.length;
      html += '<div class="search-group">'+
        '<h3 class="search-group-title">'+sheet+' <span>('+matches.length+')</span></h3>'+
        '<ul class="search-list">'+
          matches.map(function(p){
            var snippet = getSnippet(p.content || p.excerpt || '', q);
            return '<li>'+
              '<a href="#" class="search-result-link" data-post-id="'+esc(p.id)+'" data-post-sheet="'+sheet+'">'+
                '<span class="search-result-title">'+highlight(esc(p.title), q)+'</span>'+
                (snippet ? '<span class="search-result-snippet">'+highlight(esc(snippet), q)+'</span>' : '')+
              '</a></li>';
          }).join('')+
        '</ul></div>';
    });

    status.textContent = total ? ('Found '+total+' result'+(total>1?'s':'')) : 'No results found for "'+query+'".';
    results.innerHTML  = html;
    attachPostLinks(results);
  }

  function getSnippet(text, q) {
    var idx = text.toLowerCase().indexOf(q);
    if (idx < 0) return text.slice(0, 100);
    var start = Math.max(0, idx - 40);
    var end   = Math.min(text.length, idx + q.length + 60);
    return (start > 0 ? '…' : '') + text.slice(start, end) + (end < text.length ? '…' : '');
  }

  function highlight(text, q) {
    var re = new RegExp('('+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')+')', 'gi');
    return text.replace(re, '<mark>$1</mark>');
  }
})();
</script>
