---
layout: layout.njk
title: Stories
permalink: /stories/
---

<h2 class="section-heading reveal">Stories</h2>
<div class="section-rule reveal"><span>📜</span></div>

<div id="stories-container">
  <div class="loading-state"><div class="spinner-small"></div>Loading from the archive…</div>
</div>

<script>
(function(){
  var apiUrl = getApiUrl();
  var container = document.getElementById('stories-container');

  if (!apiUrl) {
    container.innerHTML = '<p class="empty-state">No database connected.</p>';
    return;
  }

  var cached = getCached('list_Stories');
  if (cached) { render(cached); return; }

  fetch(apiUrl+'?action=list&sheet=Stories')
    .then(function(r){ return r.json(); })
    .then(function(j){
      var data = j.data || [];
      setCached('list_Stories', data);
      render(data);
    })
    .catch(function(){ container.innerHTML='<p class="empty-state">Could not load stories.</p>'; });

  function render(rows) {
    var published = rows.filter(function(p){ return p.status!=='draft'; }).reverse();
    if (!published.length) {
      container.innerHTML='<p class="empty-state">No stories have been penned yet. The inkwell is full and waiting.</p>';
      return;
    }
    container.innerHTML = '<div class="listing-grid">'+
      published.map(function(p){
        return '<a href="#" class="listing-card reveal" data-post-id="'+esc(p.id)+'" data-post-sheet="Stories">'+
          '<div class="card-tag">Short Story</div>'+
          '<h3 class="card-title">'+esc(p.title)+'</h3>'+
          (p.excerpt ? '<p class="card-excerpt">'+esc(p.excerpt)+'</p>' : '')+
          '<div class="card-footer">'+
            '<span class="card-date">'+esc(p.date)+'</span>'+
            (p.content ? '<span class="reading-time">'+readingTime(p.content)+'</span>' : '')+
          '</div>'+
        '</a>';
      }).join('')+
    '</div>';
    attachPostLinks(container);
  }
})();
</script>
